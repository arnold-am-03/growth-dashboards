# Copia a .env para desarrollo local (no se versiona).

# Firma de sesiones y códigos OTP. Generar con:
#   python -c "import os;print(os.urandom(32).hex())"
SECRET_KEY=pega-aqui-una-clave-larga-y-aleatoria

# Correos con acceso (separados por coma). Si se omite, aplica la lista
# por defecto: aaguirre@prestamype.com, rhinojosa@prestamype.com
ALLOWED_EMAILS=aaguirre@prestamype.com,rhinojosa@prestamype.com

# SMTP para enviar los códigos. Con Google Workspace:
#   1) Activa verificación en 2 pasos en la cuenta emisora
#   2) Genera un "App password" (Contraseñas de aplicaciones)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=cuenta@prestamype.com
SMTP_PASSWORD=app-password-de-16-caracteres
# SMTP_FROM=Growth Innovation <cuenta@prestamype.com>

# Sin SMTP configurado (desarrollo), el PIN se imprime en los logs.
