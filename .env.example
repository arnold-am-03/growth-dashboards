# Copia a .env para desarrollo local (no se versiona).

# Firma de sesiones y códigos OTP. Generar con:
#   python -c "import os;print(os.urandom(32).hex())"
SECRET_KEY=pega-aqui-una-clave-larga-y-aleatoria

# Correos con acceso (separados por coma). Si se omite, aplica la lista
# por defecto: aaguirre@prestamype.com, rhinojosa@prestamype.com
ALLOWED_EMAILS=aaguirre@prestamype.com,rhinojosa@prestamype.com

# --- Envío de códigos (elegir UNA vía) ---

# Vía recomendada (funciona en Render, que bloquea SMTP saliente):
# API de Brevo. La clave se crea en Brevo -> SMTP y API -> Claves API.
BREVO_API_KEY=xkeysib-...
SMTP_FROM=aaguirre@prestamype.com   # remitente verificado en Brevo

# Vía alternativa (hosts que sí permiten SMTP saliente):
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=b1761...@smtp-brevo.com
# SMTP_PASSWORD=clave-smtp

# Sin nada configurado (desarrollo), el PIN se imprime en los logs.
